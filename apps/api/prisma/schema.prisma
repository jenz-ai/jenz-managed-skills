// Gate-core schema. Enums mirror packages/shared/types.ts 1:1 (frozen Contract 1).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Risk verdict — mirrors `Risk` union in @jenz/shared.
enum Risk {
  pending
  safe
  suspicious
  malicious
}

/// mirrors `Severity` union in @jenz/shared.
enum Severity {
  critical
  high
  medium
  low
}

/// mirrors `Detector` union in @jenz/shared.
enum Detector {
  regex
  llm
}

/// mirrors `SkillSource` union in @jenz/shared.
enum SkillSource {
  github
  upload
  mcp
  inline
}

/// An audited skill (a SKILL.md + bundled files). The gate releases `files`
/// only when `risk == safe`.
model Skill {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  source      SkillSource
  sourceRef   String?
  risk        Risk        @default(pending)
  description String?
  category    String?
  /// sha256 of the audited file bytes (canonical, path-sorted). The gate
  /// re-verifies this before releasing files — a mismatch means the bytes
  /// changed since the audit, so it fails closed. Nullable for pre-hash rows.
  contentHash String?
  files       SkillFile[]
  findings    Finding[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

/// A platform user. Identity comes from Supabase Auth — `id` is the Supabase
/// `auth.users.id`. The dashboard authenticates requests with a Supabase JWT;
/// the agent-facing gate/audit API stays OPEN and never touches this model.
model User {
  id        String     @id /// = Supabase auth.users.id (uuid)
  email     String     @unique
  workspace Workspace?
  createdAt DateTime   @default(now())
}

/// A workspace, owned by exactly one user (minimal single-workspace-per-user
/// for now — invites/multi-member are deferred). Skills are NOT scoped to a
/// workspace yet; the audited library is shared. `slug` is used in CLI/MCP copy.
model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId   String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SkillFile {
  id      String @id @default(cuid())
  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)
  skillId String
  path    String
  content String

  @@unique([skillId, path])
}

model Finding {
  id       String   @id @default(cuid())
  skill    Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  skillId  String
  type     String
  severity Severity
  file     String
  line     Int
  quote    String
  detector Detector
}
