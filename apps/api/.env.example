# apps/api/.env.example — copy to apps/api/.env (gitignored) and fill in.

# ── Audit model (OpenRouter) ───────────────────────────────────
OPENROUTER_API_KEY=
AUDIT_MODEL=deepseek/deepseek-chat          # confirm exact DeepSeek V4 slug at openrouter.ai/models
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AUDIT_TEMPERATURE=0.4                        # double-pass self-consistency (detection-engine.md #6)

# ── Database (platform/gate only — the audit engine does NOT need this) ──
# Hosted Supabase (no Docker). Real values live in the Railway `web` service env.
# DATABASE_URL = pooled :6543 (app) · DIRECT_URL = session pooler :5432 (Prisma migrations).
DATABASE_URL="postgresql://postgres.<ref>:<password>@<pooler-host>:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<ref>:<password>@<pooler-host>:5432/postgres"

# ── Server ─────────────────────────────────────────────────────
PORT=8080
