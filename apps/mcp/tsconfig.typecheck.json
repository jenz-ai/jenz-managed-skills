{
  // Typecheck-only config: covers mock/ and tests/ too (the build tsconfig.json compiles
  // src/ -> dist/ and must keep rootDir:"src", so it can't include these). noEmit + a wider
  // rootDir let us catch type drift in the mock and tests without changing the build output.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": ".",
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "mock/**/*.ts", "tests/**/*.ts"]
}
